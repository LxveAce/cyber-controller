{
  "name": "HaleHound",
  "id": "halehound",
  "description": "Multi-protocol IoT attack firmware for CYD touchscreen boards — WiFi, BLE, SubGHz (CC1101), 2.4GHz (NRF24), NFC (PN532). v3.5.5.",
  "backend": "esptool",
  "protocol": "halehound",
  "boards": [
    {
      "name": "ESP32 CYD 2.8\" (ESP32-2432S028R)",
      "chip": "esp32",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m",
      "has_display": true,
      "display_type": "ili9341",
      "board_id": "esp32-cyd",
      "external_modules": ["CC1101", "NRF24L01", "PN532"]
    },
    {
      "name": "QDtech E32R35T CYD 3.5\"",
      "chip": "esp32",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m",
      "has_display": true,
      "display_type": "ili9341",
      "board_id": "E32R35T",
      "external_modules": ["CC1101", "NRF24L01", "PN532"]
    },
    {
      "name": "QDtech E32R28T CYD 2.8\"",
      "chip": "esp32",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m",
      "has_display": true,
      "display_type": "ili9341",
      "board_id": "E32R28T",
      "external_modules": ["CC1101", "NRF24L01", "PN532"]
    },
    {
      "name": "NM-RF-Hat",
      "chip": "esp32",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m",
      "board_id": "NM-RF-Hat",
      "external_modules": ["CC1101", "NRF24L01", "PN532"]
    }
  ],
  "default_baud": 115200,
  "firmware_urls": {
    "repo": "https://github.com/JesseCHale/HaleHound-CYD",
    "latest": "https://github.com/JesseCHale/HaleHound-CYD/releases/latest"
  },
  "note": "Fixed from HaleHound/HaleHound to JesseCHale/HaleHound-CYD (the real upstream; matches flash_core _HALEHOUND_API). asset_match excludes OTA/ota .bins: the OTA update is an app-only image that must NOT be cold-flashed at 0x0 like the FULL merged image (it belongs to the running firmware's OTA path). exclude is case-sensitive so both casings are listed; current releases ship no .bin assets yet, so this is a latent guard.",
  "repo": "JesseCHale/HaleHound-CYD",
  "core_id": "halehound",
  "supports_suicide": false,
  "image_model": "merged-single-bin",
  "resolver": "github_release",
  "app_offset": "0x0",
  "support_files": null,
  "variants_for_chip": "by_chip",
  "default_variant": {"strategy": "prefer_fragment", "prefer": ["FULL"]},
  "resolver_params": {
    "api_url": "https://api.github.com/repos/JesseCHale/HaleHound-CYD/releases/latest",
    "on_error": "source_only_empty",
    "asset_match": {"include_suffixes": [".bin"], "exclude_substrings": ["OTA", "ota"]},
    "chip_map": {"strategy": "fixed", "chip": "esp32"},
    "emit": {"offset": "0x0", "merged": true, "label_template": "HaleHound CYD", "label_suffix_rules": [["FULL", " (merged full)"], ["OTA", " (OTA update)"]]}
  }
}
