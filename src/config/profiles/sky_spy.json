{
  "name": "Sky-Spy",
  "label": "Sky-Spy Drone RemoteID (colonelpanichacks)",
  "id": "sky_spy",
  "core_id": "sky-spy",
  "description": "Drone detector — passively listens for WiFi Remote ID / Open Drone ID broadcasts to spot nearby UAVs and surface their operator/location data. Does NOT track ADS-B aircraft.",
  "backend": "esptool",
  "protocol": null,
  "boards": [
    {
      "name": "ESP32-S3 Generic",
      "chip": "esp32s3",
      "flash_size": "8MB",
      "flash_mode": "dio",
      "flash_freq": "80m"
    },
    {
      "name": "ESP32-C6 Generic",
      "chip": "esp32c6",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m"
    }
  ],
  "default_baud": 115200,
  "firmware_urls": {
    "repo": "https://github.com/colonelpanichacks/Sky-Spy",
    "latest": "https://github.com/colonelpanichacks/Sky-Spy/releases/latest"
  },
  "note": "colonelpanichacks/Sky-Spy. Drone Remote ID / Open Drone ID detector — NOT ADS-B aircraft.",
  "repo": "colonelpanichacks/Sky-Spy",
  "supports_suicide": false,
  "image_model": "merged-single-bin",
  "resolver": "github_release",
  "app_offset": "0x0",
  "support_files": null,
  "variants_for_chip": "by_chip",
  "default_variant": {"strategy": "first"},
  "resolver_params": {
    "api_url": "https://api.github.com/repos/colonelpanichacks/Sky-Spy/releases/latest",
    "asset_match": {"include_suffixes": [".bin"], "include_regex": "^(.*)\\.bin$"},
    "chip_map": {
      "strategy": "fragments", "source": "name", "default": "esp32",
      "rules": [["s3", "esp32s3"]]
    },
    "emit": {
      "offset": "0x0", "merged": true,
      "label_template": "Sky-Spy {env}", "label_group": 1
    },
    "on_error": "source_only_empty"
  }
}
