      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m",
      "arming_pin": 27,
      "partitions": {
        "bootloader": {"offset": "0x1000"},
        "partitions": {"offset": "0x8000"},
        "firmware": {"offset": "0x10000"}
      }
    },
    {
