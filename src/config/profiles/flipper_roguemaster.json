{
  "name": "Flipper Zero — RogueMaster",
  "id": "flipper_roguemaster",
  "description": "RogueMaster custom firmware for Flipper Zero",
  "backend": "qflipper",
  "protocol": "flipper",
  "boards": [
    {
      "name": "Flipper Zero",
      "chip": "stm32wb55",
      "flash_size": "1MB"
    }
  ],
  "firmware_urls": {
    "latest": "https://github.com/RogueMaster/flipperzero-firmware-wPlugins/releases/latest"
  },
  "note": "RogueMaster/flipperzero-firmware-wPlugins. Flipper Zero STM32WB55 firmware shipped as a packaged update (.tgz/.tar.gz/.zip); flashed via the external qFlipper tool, not esptool. Single merged package at 0x0; chip fixed to 'flipper'. Combines Unleashed plus extra apps/plugins; actively maintained.",
  "repo": "RogueMaster/flipperzero-firmware-wPlugins",
  "core_id": "roguemaster",
  "label": "Flipper RogueMaster",
  "supports_suicide": false,
  "image_model": "merged-single-bin",
  "resolver": "github_release",
  "app_offset": "0x0",
  "support_files": null,
  "variants_for_chip": "all",
  "default_variant": {"strategy": "first"},
  "resolver_params": {
    "api_url": "https://api.github.com/repos/RogueMaster/flipperzero-firmware-wPlugins/releases/latest",
    "asset_match": {"include_suffixes": [".tgz", ".tar.gz", ".zip"]},
    "chip_map": {"strategy": "fixed", "chip": "flipper"},
    "emit": {
      "offset": "0x0",
      "merged": true,
      "flash_method": "qflipper",
      "label_template": "RogueMaster {name}"
    }
  }
}
