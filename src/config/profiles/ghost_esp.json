{
  "name": "GhostESP",
  "id": "ghost_esp",
  "description": "Lightweight WiFi/BLE scanning, monitoring, and deauth firmware. Per-board merged single .bin (flashed at 0x0).",
  "backend": "esptool",
  "protocol": "ghost_esp",
  "boards": [
    {
      "name": "ESP32 Generic",
      "chip": "esp32",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m"
    },
    {
      "name": "ESP32-S3 DevKitC-1",
      "chip": "esp32s3",
      "flash_size": "8MB",
      "flash_mode": "dio",
      "flash_freq": "80m"
    },
    {
      "name": "ESP32-C5 DevKitC-1",
      "chip": "esp32c5",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m"
    },
    {
      "name": "ESP32-C6 DevKitC-1",
      "chip": "esp32c6",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m"
    },
    {
      "name": "ESP32 CYD 2.8\" Touchscreen",
      "chip": "esp32",
      "flash_size": "4MB",
      "flash_mode": "dio",
      "flash_freq": "80m",
      "has_display": true,
      "display_type": "ili9341"
    }
  ],
  "default_baud": 115200,
  "firmware_urls": {
    "repo": "https://github.com/GhostESP-Revival/GhostESP",
    "latest": "https://github.com/GhostESP-Revival/GhostESP/releases/latest"
  },
  "note": "Aligned to GhostESP-Revival/GhostESP (canonical, matches flash_core _GHOSTESP_API). Older Spooks4576/Ghost_ESP is deprecated.",
  "label": "GhostESP (GhostESP-Revival)",
  "core_id": "ghostesp",
  "repo": "GhostESP-Revival/GhostESP",
  "supports_suicide": false,
  "image_model": "merged-single-bin",
  "resolver": "github_release",
  "app_offset": "0x0",
  "support_files": null,
  "variants_for_chip": "by_chip",
  "default_variant": {"strategy": "prefer_fragment", "prefer": ["generic", "devkitc"]},
  "resolver_params": {
    "api_url": "https://api.github.com/repos/GhostESP-Revival/GhostESP/releases/latest",
    "asset_match": {
      "include_regex": "^(.+)\\.(zip|bin)$",
      "regex_flags": ["IGNORECASE"],
      "exclude_substrings": ["bootloader", "partitions", "boot_app0"]
    },
    "chip_map": {
      "strategy": "fragments", "source": "name", "default": "esp32",
      "rules": [
        ["esp32-s3-devkitc-1", "esp32s3"],
        ["esp32-s3-zero", "esp32s3"],
        ["cardputer", "esp32s3"],
        ["cyd-2432s028", "esp32"],
        ["esp32-c5-devkitc-1", "esp32c5"],
        ["esp32-c6-devkitc-1", "esp32c6"],
        ["xiao_esp32_s3", "esp32s3"],
        ["lilygo-t-display-s3", "esp32s3"],
        ["waveshare-esp32-s3-touch-lcd-1.28", "esp32s3"],
        ["s3", "esp32s3"],
        ["c5", "esp32c5"],
        ["c6", "esp32c6"]
      ]
    },
    "emit": {
      "offset": "0x0",
      "merged": true,
      "zip_member": "merged.bin",
      "label_template": "GhostESP {env}",
      "label_group": 1
    }
  }
}
